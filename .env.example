# ─── DATABASE ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/aura_search

# ─── SERVER ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT SECRET (min 32 characters) ────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here

# ─── AI & SEARCH APIs ──────────────────────────────────────────────────────
MISTRAL_AI_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── EMAIL (Gmail) ────────────────────────────────────────────────────────
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── AI MODEL (optional) ───────────────────────────────────────────────────
MISTRAL_MODEL=mistral-medium-latest
